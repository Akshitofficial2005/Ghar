# Production Server Configuration
PORT=5001
NODE_ENV=production

# Production Database - UPDATE WITH YOUR MONGODB ATLAS CONNECTION
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ghar-production

# JWT Configuration
JWT_SECRET=your-production-jwt-secret
JWT_EXPIRE=7d

REQUIRE_REGISTRATION_OTP=true

# Production Razorpay - UPDATE WITH YOUR LIVE KEYS
RAZORPAY_KEY_ID=rzp_live_YOUR_LIVE_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_LIVE_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# Production Cloudinary - UPDATE WITH YOUR CREDENTIALS
CLOUDINARY_CLOUD_NAME=your-production-cloud-name
CLOUDINARY_API_KEY=your-production-api-key
CLOUDINARY_API_SECRET=your-production-api-secret

# Production Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=noreply@gharapp.com
EMAIL_PASS=your-production-app-password
EMAIL_FROM=noreply@gharapp.com

# Gmail OTP fallback
GMAIL_USER=noreply@yourdomain.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Production Frontend URL - UPDATE AFTER VERCEL DEPLOYMENT
FRONTEND_URL=https://your-app-name.vercel.app

# Google OAuth removed
